#!/usr/bin/env sh

shot-win() {
	grimblast copy active
}

shot-area() {
	grimblast --freeze copy area
}

shot-ocr-area() {
	grimblast --freeze save area - | tesseract stdin stdout -l eng+ukr+rus 2>/dev/null | wl-copy
}

shot-screen() {
	grimblast copy output
}

if [ "$1" = "--win" ]; then
	shot-win
elif [ "$1" = "--area" ]; then
	shot-area
elif [ "$1" = "--screen" ]; then
	shot-screen
elif [ "$1" = "--ocr-area" ]; then
	shot-ocr-area
else
	echo "Available: --win --area --screen --ocr-area"
fi