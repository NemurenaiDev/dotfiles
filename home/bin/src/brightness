#!/usr/bin/env sh

get_backlight() {
    echo $(brightnessctl -m | cut -d, -f4)
}

change_backlight() {
    brightnessctl set "$1"
}

case "$1" in
"--get")
    get_backlight
    ;;
"--inc")
    change_backlight "+1%"
    ;;
"--dec")
    change_backlight "1%-"
    ;;
*)
    get_backlight
    ;;
esac
