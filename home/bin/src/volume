#!/usr/bin/env sh

iDIR="$XDG_DATA_HOME/assets/icons"

get_volume() {
	volume=$(pamixer --get-volume)
	echo "$volume"
}
inc_volume() {
	pamixer --allow-boost --set-volume $(($(pamixer --get-volume) + 5 - $(pamixer --get-volume) % 5))
}
dec_volume() {
	pamixer --allow-boost --set-volume $(($(pamixer --get-volume) - 5 - $(pamixer --get-volume) % 5))
}
toggle_mute() {
	if [ "$(pamixer --get-mute)" == "false" ]; then
		pamixer -m
	elif [ "$(pamixer --get-mute)" == "true" ]; then
		pamixer -u
	fi
}


get_default_mic() {
	pactl info | awk -F': ' '/Default Source/ {print $2}'
}
toggle_mic() {
	if [ "$(pamixer --source "$(get_default_mic)" --get-mute)" == "false" ]; then
		pamixer --source "$(get_default_mic)" -m
	elif [ "$(pamixer --source "$(get_default_mic)" --get-mute)" == "true" ]; then
		pamixer -u --source "$(get_default_mic)" u
	fi
}
inc_mic_volume() {
	pamixer --source "$(get_default_mic)" -i 5
}
dec_mic_volume() {
	pamixer --source "$(get_default_mic)" -d 5
}

if [[ "$1" == "--get" ]]; then
	get_volume
elif [[ "$1" == "--inc" ]]; then
	inc_volume
elif [[ "$1" == "--dec" ]]; then
	dec_volume
elif [[ "$1" == "--toggle" ]]; then
	toggle_mute
elif [[ "$1" == "--toggle-mic" ]]; then
	toggle_mic
elif [[ "$1" == "--get-icon" ]]; then
	get_icon
elif [[ "$1" == "--get-mic-icon" ]]; then
	get_mic_icon
elif [[ "$1" == "--mic-inc" ]]; then
	inc_mic_volume
elif [[ "$1" == "--mic-dec" ]]; then
	dec_mic_volume
else
    echo -e "Available Options : --get --inc --dec --toggle --toggle-mic --get-icon --get-mic-icon --mic-inc --mic-dec"
fi
