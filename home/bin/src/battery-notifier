#!/usr/bin/env sh

BAT="${2:-/sys/class/power_supply/BATT}"
BAT_LOW_THRESHOLD="${1:-20}"

battery_status() {
	cat "$BAT/status"
}

battery_capacity() {
	cat "$BAT/capacity"
}

LOW="0"
LOW_FIRED="0"

STATUS=$(battery_status)
CAPACITY=$(battery_capacity)

while true; do
	sleep 1

	NEW_STATUS=$(battery_status)
	NEW_CAPACITY=$(battery_capacity)

	if [ "$NEW_CAPACITY" -lt "$BAT_LOW_THRESHOLD" ]; then
		NEW_LOW="1"
	else
		NEW_LOW="0"
	fi

	[ "$NEW_LOW" = "$LOW" ] && [ "$NEW_CAPACITY" = "$CAPACITY" ] && [ "$NEW_STATUS" = "$STATUS" ] && continue

	if [ "$NEW_LOW" -eq 1 ] && [ "$LOW_FIRED" -eq 0 ] && [ "$NEW_STATUS" = "Discharging" ]; then
		notify-send \
			--app-name=battery-notifier \
			-u critical \
			-c battery \
			-i "$XDG_DATA_HOME/assets/icons/battery-low.png" \
			"Low battery" \
			"Battery below ${BAT_LOW_THRESHOLD}%"

		paplay --volume 65536 "$XDG_DATA_HOME/assets/audio/low-battery.mp3"

		LOW_FIRED="1"
	fi

	if [ "$NEW_LOW" -eq 0 ] || [ "$NEW_STATUS" = "Charging" ]; then
		LOW_FIRED="0"
	fi

	if [ "$STATUS" != "$NEW_STATUS" ]; then
		case "$NEW_STATUS" in

		Charging)
			notify-send \
				--app-name=battery-notifier \
				-c battery \
				-i "$XDG_DATA_HOME/assets/icons/battery-charging.png" \
				"Charging..."
			;;

		Discharging)
			if [ "$NEW_LOW" -eq 1 ]; then
				ICON="battery-low.png"
			else
				ICON="battery-full.png"
			fi

			notify-send \
				--app-name=battery-notifier \
				-c battery \
				-i "$XDG_DATA_HOME/assets/icons/$ICON" \
				"Discharging..."
			;;

		esac
	fi

	LOW="$NEW_LOW"
	STATUS="$NEW_STATUS"
	CAPACITY="$NEW_CAPACITY"
done
